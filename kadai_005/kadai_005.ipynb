      "source": [
        "# 台形の面積\n",
        "# 変数に数値を代入\n",
        "width1 = 10\n",
        "width2 = 20\n",
        "length = 5\n",
        "\n",
        "\n",
        "# 計算結果を変数に代入\n",
        "area = (width1 + width2) * length / 2\n",
        "\n",
        "# f文字列を使って計算結果と単位（cm²）を表示\n",
        "print(f\"{area} cm²\")\n",
        "\n"
      ]
    }
  ]
}